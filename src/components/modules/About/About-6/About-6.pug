section.section-service-diff
	.container
		h2.section-title(data-ripple-text data-ripple-text-types="words" data-ripple-text-delay="0.08")
			| SỰ KHÁC BIỆT DỊCH VỤ

		.service-list(data-stagger data-stagger-delay="0.14" data-stagger-duration="0.7")
			//- Card 1 — ACF repeater: service_items
			.service-card(data-stagger-item)
				.service-card__head
					h3.service-card__title
						| An tâm về
						strong  CHẤT LƯỢNG
					.service-card__icon
						i.fa-regular.fa-wrench
				.service-card__body
					ul
						li Dây chuyền hiện đại, tuân thủ nghiệm ngặt các tiêu chuẩn ISO 9001 và IATF 16949
						li Đảm bảo độ bền, độ chắc chắn và tính thẩm mỹ

			//- Card 2
			.service-card(data-stagger-item)
				.service-card__head
					h3.service-card__title
						| An tâm về
						strong  TIỆN ÍCH
					.service-card__icon
						i.fa-regular.fa-gear
				.service-card__body
					p Cung cấp giải pháp thực tế giúp bảo vệ các bộ phận của xe, từ đó tối ưu chi phí bảo dưỡng, mang đến cho chủ xe sự an tâm trên mọi hành trình.

			//- Card 3
			.service-card(data-stagger-item)
				.service-card__head
					h3.service-card__title
						| An tâm về
						strong  CHÍNH SÁCH
					.service-card__icon
						i.fa-regular.fa-headset
				.service-card__body
					p Giá trị cốt lõi “Khách hàng là trung tâm”